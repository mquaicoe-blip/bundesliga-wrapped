# ─────────────────────────────────────────────────────────────────────────────
# Bundesliga Wrapped — environment variable template
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored. Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# S3 bucket that holds your copy of the hackathon data.
# Format: hackathon-data-<your-12-digit-AWS-account-id>
# Find your account ID: aws sts get-caller-identity --query Account --output text
HACKATHON_BUCKET=hackathon-data-XXXXXXXXXXXX

# AWS region where the bucket and Bedrock endpoint live.
# Must be eu-central-1 for this hackathon.
AWS_DEFAULT_REGION=eu-central-1

# ── SSO (preferred for local dev) ────────────────────────────────────────────
# The named AWS profile to try first. If this profile exists and has valid
# credentials, env vars below are ignored.
# Set to "hackathon" if you configure SSO: aws configure sso --profile hackathon
# Leave as "default" to use whatever profile aws configure set up.
AWS_PROFILE=default

# ── Fallback: explicit credentials (CI / no SSO) ─────────────────────────────
# Leave blank if using SSO. Fill in if running in a pipeline or on a machine
# where `aws sso login` is not available.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Session token is required when using temporary credentials (STS / assumed role)
AWS_SESSION_TOKEN=

# ── Bedrock model ─────────────────────────────────────────────────────────────
# Model ID used for all narrative generation.
# Default: Claude Sonnet 4 (claude-sonnet-4-6) — change only if you want to
# experiment with a different foundation model.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5

# ── App settings ──────────────────────────────────────────────────────────────
# Default narrative tone for Wrapped generation.
# Options: commentator | analyst | fan
DEFAULT_TONE=commentator

# Log level for the Python backend (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
